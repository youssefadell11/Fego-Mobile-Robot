<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="blue">
        <color rgba="0 0 1 0.5"/> 
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/> 
    </material>
    
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <link name="base_footprint"/>

    <joint name="base_footprint_to_base_link_joint" type="fixed">
        <parent link="base_footprint"/> 
        <child link="base_link"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/> 
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.6 0.4 0.2"/> 
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0"/> 
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.6 0.4 0.2"/> 
            </geometry>
            <origin xyz="0 0 0.1" rpy="0 0 0"/> 
        </collision>
        <inertial>
            <origin xyz="0 0 0.1" rpy="0 0 0"/> 
            <mass value="2.0"/>
            <inertia ixx="0.033333" ixy="0.0" ixz="0.0"
                     iyy="0.066667" iyz="0.0"
                     izz="0.086667"/>
        </inertial>
    </link>

    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
    </gazebo>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/> 
        <child link="right_wheel_link"/>
        <origin xyz="-0.15 -0.225 0" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/> 

        <limit effort="1000.0" velocity="100.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint> 

    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.05"/> 
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <mass value="2.5"/>
            <inertia ixx="0.006771" ixy="0.0" ixz="0.0"
                     iyy="0.006771" iyz="0.0"
                     izz="0.012500"/>
        </inertial>
    </link>

    <gazebo reference="right_wheel_link">
        <material>Gazebo/Red</material>
    </gazebo>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/> 
        <child link="left_wheel_link"/>
        <origin xyz="-0.15 0.225 0" rpy="0 0 0"/> 
        <axis xyz="0 1 0"/> 

        <limit effort="1000.0" velocity="100.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="left_wheel_link">
        <visual>        
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>  
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.1" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.57 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="1.57 0 0"/> 
            <mass value="2.5"/>
            <inertia ixx="0.006771" ixy="0.0" ixz="0.0"
                     iyy="0.006771" iyz="0.0"
                     izz="0.012500"/>
        </inertial>
    </link>

    <gazebo reference="left_wheel_link">
        <material>Gazebo/Red</material>
    </gazebo>

    <joint name="base_castor_wheel_joint" type="fixed">
        <parent link="base_link"/> 
        <child link="castor_wheel_link"/>
        <origin xyz="0.2 0 -0.05" rpy="0 0 0"/>  
    </joint>

    <link name="castor_wheel_link">
        <visual>
            <geometry>
                <sphere radius="0.05" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>  
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.05" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>  
            <inertia ixx="0.001000" ixy="0.0" ixz="0.0"
                     iyy="0.001000" iyz="0.0"
                     izz="0.001000"/>
        </inertial>
    </link>

    <gazebo reference="castor_wheel_link">
        <material>Gazebo/Black</material>
        <mu1>0.0</mu1>
        <mu2>0.0</mu2>
    </gazebo>

</robot>