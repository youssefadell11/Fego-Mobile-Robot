<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="blue">
        <color rgba="0 0 1 1"/> 
    </material>

    <material name="red">
        <color rgba="1 0 0 0.5"/> 
    </material>
    
    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <link name="base_footprint"/>

    <joint name="base_footprint_to_base_link_joint" type="fixed">
        <parent link="base_footprint"/> 
        <child link="base_link"/>
        <origin xyz="0 0 0.0125" rpy="0 0 0"/> 
    </joint>

    <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://${pkg}/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 1.5708"/> 
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.2 0.15 0.05"/>
            </geometry>
            <origin xyz="0 0 0.02" rpy="0 0 0"/> 
        </collision>
        <inertial>
            <origin xyz="0 0 0.02" rpy="0 0 0"/> 
            <mass value="2.0"/>
            <inertia ixx="0.004566" ixy="0.0" ixz="0.0" 
                     iyy="0.007483" iyz="0.0" 
                     izz="0.010416"/>
        </inertial>
    </link>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link"/> 
        <child link="right_wheel_link"/>
        <origin xyz="0.022 -0.093 0.02" rpy="0 0 0"/> 
        
        <axis xyz="0 1 0"/> 
        
        <limit effort="1000.0" velocity="100.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint> 

    <link name="right_wheel_link">
        <visual>
            <geometry>
                <mesh filename="package://${pkg}/meshes/wheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 -1.5708"/> 
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0325" length="0.026"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/> 
            <mass value="0.04"/>
            <inertia ixx="0.0000128" ixy="0.0" ixz="0.0" 
                     iyy="0.0000211" iyz="0.0" 
                     izz="0.0000128"/>
        </inertial>
    </link>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link"/> 
        <child link="left_wheel_link"/>
        <origin xyz="0.022 0.093 0.02" rpy="0 0 0"/> 
        
        <axis xyz="0 1 0"/> 
        
        <limit effort="1000.0" velocity="100.0"/>
        <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <link name="left_wheel_link">
        <visual>        
            <geometry>
                <mesh filename="package://${pkg}/meshes/wheel.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 1.5708"/>  
            <material name="red"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.0325" length="0.026"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="1.5708 0 0"/> 
            <mass value="0.04"/>
            <inertia ixx="0.0000128" ixy="0.0" ixz="0.0" 
                     iyy="0.0000211" iyz="0.0" 
                     izz="0.0000128"/>
        </inertial>
    </link>

    <joint name="base_castor_wheel_joint" type="fixed">
        <parent link="base_link"/> 
        <child link="castor_wheel_link"/>
        <origin xyz="-0.075 0 0.0025" rpy="0 0 0"/>  
    </joint>

    <link name="castor_wheel_link">
        <visual>
            <geometry>
                <mesh filename="package://${pkg}/meshes/caster.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 1.5708"/>  
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.015" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>  
            <mass value="0.05"/>
            <inertia ixx="0.0000045" ixy="0.0" ixz="0.0" 
                     iyy="0.0000045" iyz="0.0" 
                     izz="0.0000045"/>
        </inertial>
    </link>

</robot>